# ╔══════════════════════════════════════════════════════════════╗
# ║                    TASKLANE — ENV CONFIG                     ║
# ║  Copy this file to .env and fill in your values.             ║
# ║  cp .env.example .env                                        ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Database (PostgreSQL) ──────────────────────────────────────
# Connection string for Prisma. Matches docker-compose defaults.
DATABASE_URL="postgresql://tasklane:tasklane_secret@localhost:5432/tasklane_dev?schema=public"

# ── Redis ──────────────────────────────────────────────────────
# Used for caching, session store, and Socket.io adapter.
REDIS_URL="redis://localhost:6379"

# ── Authentication (JWT) ──────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET="change-me-to-a-random-secret"
JWT_REFRESH_SECRET="change-me-to-a-different-random-secret"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ── AI / LLM ──────────────────────────────────────────────────
# Groq API key for AI-powered features (task summarization, etc.)
GROQ_API_KEY="your-groq-api-key-here"
GEMINI_API_KEY="your-gemini-api-key-here"
AI_MODEL_PRIMARY=llama-3.3-70b-versatile
AI_MODEL_FALLBACK=gemini-2.0-flash
AI_RATE_LIMIT_PER_HOUR=20
AI_CACHE_TTL_SECONDS=86400
LOG_AI_CALLS=true

# ── Email (Resend) ────────────────────────────────────────────
# Production email delivery via Resend (https://resend.com)
RESEND_API_KEY=""
EMAIL_FROM="noreply@tasklane.app"

# ── Email (Dev — Mailhog) ─────────────────────────────────────
# Mailhog SMTP for local dev (see docker-compose.yml)
SMTP_HOST="localhost"
SMTP_PORT="1025"

# ── Frontend URLs ─────────────────────────────────────────────
# Used by the API for CORS and redirect URLs
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── API Server ────────────────────────────────────────────────
API_PORT="3001"
NODE_ENV="development"

# ── File Uploads ──────────────────────────────────────────────
# S3-compatible storage for file attachments (optional)
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""

# ── Observability (optional) ──────────────────────────────────
# Sentry DSN for error tracking
SENTRY_DSN=""
LOG_LEVEL="debug"
